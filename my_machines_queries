//1
-- שאילתה למציאת המכונות הכי יעילות במפעל
SELECT
Machine_ID, AVG(Efficiency_Score) AS avgScore
FROM Production_Logs
GROUP BY Machine_ID
HAVING AVG(Efficiency_Score) >= 85;
//2
-- חיבור נתוני ייצור עם סוג המכונה 
SELECT
P.Batch_ID, M.Machine_Type
FROM Production P
JOIN Machines M ON P.Machine_ID = M.Machine_ID;
//3
-- נקבץ יח' שיוצרו לפי יום במפעל
SELECT p.WorkDate, SUM(p.Units_Produced)
FROM Production_Log p
GROUP BY p.WorkDate
ORDER BY p.WorkDate DESC;
//4
-- שאילתא בתוך שאילתא. משמשת בתור "מספר" בתוך התנאי. השוואת רשימה לערך ע"י שאילתא
SELECT *
FROM Production_Log
WHERE Units_Produced > (SELECT AVG(Units_Produced) FROM Production_Log);
//5
--  סיכום ייצור, אחוז פגומים ודירוג איכות
SELECT 
    M.ModelName, 
    SUM(P.Units_Produced) AS Total_Produced,
    -- חישוב אחוז הפגומים (הכפלה ב-1.0 למניעת עיגול מספרים שלמים)
    SUM(P.Scrap_Units) * 1.0 / SUM(P.Units_Produced) AS Scrap_Rate,
    -- דירוג המכונות לפי כמות היחידות התקינות (ייצור פחות פגומים)
    DENSE_RANK() OVER (ORDER BY (SUM(P.Units_Produced) - SUM(P.Scrap_Units)) DESC) AS Efficiency_Rank
FROM Machines M
JOIN Production_Log P ON M.MachineID = P.MachineID
GROUP BY M.MachineID, M.ModelName
ORDER BY Total_Produced DESC;
//5+
-- הדוח הקודם פלוס סיווג המכונה לפי אחוזיפגומים (שימוש ב case)
SELECT 
    M.ModelName, 
    SUM(P.Units_Produced) AS Total_Produced,
    -- חישוב אחוז הפגומים (Scrap Rate)
    SUM(P.Scrap_Units) * 1.0 / SUM(P.Units_Produced) AS Scrap_Rate,
    -- סיווג איכות המכונה לפי אחוז הפגומים
    CASE 
        WHEN (SUM(P.Scrap_Units) * 1.0 / SUM(P.Units_Produced)) < 0.02 THEN 'Excellent'
        WHEN (SUM(P.Scrap_Units) * 1.0 / SUM(P.Units_Produced)) <= 0.05 THEN 'Good'
        ELSE 'Needs Review'
    END AS Performance_Status,
    -- דירוג המכונות לפי כמות היחידות התקינות (ייצור פחות פגומים)
    DENSE_RANK() OVER (ORDER BY (SUM(P.Units_Produced) - SUM(P.Scrap_Units)) DESC) AS Efficiency_Rank 
FROM Machines M
JOIN Production_Log P ON M.MachineID = P.MachineID
GROUP BY M.MachineID, M.ModelName
ORDER BY Total_Produced DESC;
//6
טבלה זמנית, פונק לאג
WITH ShiftHistory AS (
    SELECT 
        MachineID,
        Units_Produced AS Current_Shift,
        LAG(Units_Produced, 1) OVER(PARTITION BY MachineID ORDER BY ShiftID) AS Prev_1,
        LAG(Units_Produced, 2) OVER(PARTITION BY MachineID ORDER BY ShiftID) AS Prev_2
    FROM Production_Log
)
SELECT DISTINCT MachineID
FROM ShiftHistory
WHERE Current_Shift > 100 
  AND Prev_1 > 100 
  AND Prev_2 > 100;

